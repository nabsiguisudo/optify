# Required only for AI recommendation / copilot features.
OPENAI_API_KEY=

# Required only if billing is enabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
